*.backup
*.bak
*.swp
*~
Thumbs.db

# Python caches, virtual environments and Jupyter notebooks checkpoints
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ipynb_checkpoints/
venv/
.venv/
env/

# ML models and large training output files
*.h5
*.keras
*.tflite
ml/output/

# typescript
*.tsbuildinfo

app-example

# ML module folder
ml/

# generated native folders
/ios
/android
